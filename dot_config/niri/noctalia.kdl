layout {

    focus-ring {
        active-color   "#adc6ff"
        inactive-color "#11131a"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#adc6ff"
        inactive-color "#11131a"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#adc6ff"
        inactive-color "#004494"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#adc6ff80"
    }
}

recent-windows {
    highlight {
        active-color "#adc6ff"
        urgent-color "#ffb4ab"
    }
}

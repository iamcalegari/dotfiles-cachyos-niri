layout {

    focus-ring {
        active-color   "#c5c0ff"
        inactive-color "#131317"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#c5c0ff"
        inactive-color "#131317"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#c5c0ff"
        inactive-color "#433f7f"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#c5c0ff80"
    }
}

recent-windows {
    highlight {
        active-color "#c5c0ff"
        urgent-color "#ffb4ab"
    }
}
